# Auth API base URL (Auth-клиент axios; withCredentials только для него)
VITE_AUTH_API_BASE_URL=/api/auth

# Realm-константа деплоя (domain/group), обязательна на signin/signup/check-login
VITE_AUTH_REALM=print-shop/standard

# Стратегия хранения refresh: cookie (веб-прод) | body (dev/кросс-домен)
VITE_TOKEN_MODE=cookie

# Включить MSW-моки Auth API (1 = включено). В деве по умолчанию включено.
VITE_ENABLE_MOCKS=1

# Только для моков: 0 = у пользователя один кабинет (в профиле нет карточки «Кабинеты»,
# на /sessions нет выбора кабинета). По умолчанию — несколько кабинетов.
VITE_MOCK_MULTI_REALM=1
